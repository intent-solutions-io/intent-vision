{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "../..",
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*", "../../db/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
